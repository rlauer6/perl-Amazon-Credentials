package Amazon::Credentials::HTTP::UserAgent;

use strict;
use warnings;

use HTTP::Tiny;
use Amazon::Credentials::HTTP::Response;

########################################################################
sub new {
########################################################################
  my ( $class, %opts ) = @_;

  return bless { ua => HTTP::Tiny->new(%opts) }, $class;
}

########################################################################
sub request {
########################################################################
  my ( $self, $request ) = @_;

  my %headers;

  $request->headers->scan(
    sub {
      if ( lc $_[0] ne 'host' ) {
        $headers{ $_[0] } = $_[1];
      }
    }
  );

  my %opts = ( headers => \%headers );

  if ( my $content = $request->content ) {
    $opts{content} = $content;
  }

  my $response = $self->{ua}->request( $request->method, $request->uri->as_string, \%opts );

  return Amazon::Credentials::HTTP::Response->new($response);
}

1;
